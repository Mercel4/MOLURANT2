    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 105
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "MOLURANT\uB294 \uCD5C\uC801\uC758 \uAC8C\uC784 \uD658\uACBD\uC744 \uC81C\uACF5\uD558\uAE30
    \uC704\uD574 \uC11C\uBC84 \uC120\uD0DD \uAE30\uB2A5\uC744 \uC81C\uACF5\uD569\uB2C8\uB2E4.
    \uC11C\uBC84\uB97C \uC120\uD0DD\uD558\uBA74 \uC7A0\uC2DC \uD6C4 \uD574\uB2F9
    \uC11C\uBC84\uB85C \uC790\uB3D9 \uC5F0\uACB0\uB418\uBA70, \uC120\uD0DD\uD55C
    \uC11C\uBC84\uC5D0\uC11C \uCE5C\uAD6C\uC640 \uD568\uAED8 \uD50C\uB808\uC774 \uD560
    \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uB2E8, \uC11C\uBC84 \uAC04 \uB9E4\uCE6D\uC740
    \uC9C0\uC6D0\uB418\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uAE30\uBCF8\uC801\uC73C\uB85C\uB294
    \uC790\uB3D9\uC73C\uB85C \uC548\uC815\uC801\uC778 \uC11C\uBC84(\uCD5C\uC801 \uC11C\uBC84)\uC5D0
    \uC5F0\uACB0 \uB429\uB2C8\uB2E4. \uC5F0\uACB0\uC774 \uC644\uB8CC\uB418\uBA74
    \uD50C\uB808\uC774 \uBC84\uD2BC\uC744 \uB20C\uB7EC \uB9E4\uCE58 \uB300\uAE30\uC5F4\uC5D0
    \uCC38\uC5EC \uD569\uB2C8\uB2E4."
