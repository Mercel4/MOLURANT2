# Auto detect text files and perform LF normalization
* text=auto
Assets/01_Scenes/AssetDemo/PolygonNature/Terrains/*.asset filter=lfs diff=lfs merge=lfs -text
*.cs   text eol=lf
*.shader text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.dylib filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.bundle filter=lfs diff=lfs merge=lfs -text
