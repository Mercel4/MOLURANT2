  m_GameObject: {fileID: 859309703}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.9607843, g: 0.9607843, b: 0.9607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: 8965b3405de8c427491bdc8ab40df718, type: 3}
    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 3
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\uC548\uB155\uD558\uC138\uC694, \uAC8C\uC784\uC744 \uD50C\uB808\uC774\uD574
    \uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC774 \uAC8C\uC784\uC740
    \uBA40\uD2F0\uD50C\uB808\uC774\uC5B4 \uAE30\uBC18\uC774\uBBC0\uB85C \uBA3C\uC800
    \uD50C\uB808\uC774\uC5B4 \uB2C9\uB124\uC784\uC744 \uC124\uC815\uD574\uC57C \uD569\uB2C8\uB2E4.
    \uC124\uC815\uD55C \uB2C9\uB124\uC784\uC740 \uBCC0\uACBD\uD560 \uC218 \uC5C6\uC73C\uBA70,
    \uB2E4\uB978 \uD50C\uB808\uC774\uC5B4\uC640\uC758 \uAC8C\uC784 \uC9C4\uD589 \uBC0F
    \uAE30\uB85D\uC5D0 \uC0AC\uC6A9\uB429\uB2C8\uB2E4. \uC2E0\uC911\uD558\uAC8C \uC120\uD0DD\uD574
    \uC8FC\uC138\uC694. \uAC8C\uC784\uC744 \uC2DC\uC791\uD558\uB294 \uC989\uC2DC
    \uCD5C\uC885 \uC0AC\uC6A9\uC790 \uB77C\uC774\uC120\uC2A4 \uACC4\uC57D(EULA)\uC5D0
    \uB3D9\uC758\uD55C \uAC83\uC73C\uB85C \uAC04\uC8FC\uB429\uB2C8\uB2E4."
