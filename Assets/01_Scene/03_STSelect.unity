  m_Text: "\uC9D1\uD589\uC790\uB294 \uB2E8 \uD55C \uBC88\uC758 \uBC29\uC544\uC1E0\uB85C
    \uC804\uC7A5\uC744 \uC815\uB9AC\uD558\uBA70, \uB192\uC740 \uD30C\uAD34\uB825\uC744
    \uC790\uB791\uD569\uB2C8\uB2E4.\n\n\uBC00\uB808\uB2C8\uC5C4 \uC0AC\uC774\uC5B8\uC2A4
    \uC2A4\uCFE8 \uCD9C\uC2E0 \uC18C\uC18D\uC73C\uB85C \uC548\uB4DC\uB85C\uC774\uB4DC
    \uB85C\uBD07\uC774\uBA70, \uC5EC\uC131\uC758 \uBAA8\uC2B5\uC744 \uD558\uC9C0\uB9CC
    \uC131\uBCC4\uC744 \uC54C \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC77C\uBC18 \uD559\uC0DD\uB4E4\uC774\uB77C\uBA74
    \uBABB\uB4DC\uB294 \uB808\uC77C\uD3EC\uB97C \uD734\uB300\uD558\uB294 \uB4F1 \uC5C4\uCCAD\uB09C
    \uD798\uC744 \uC790\uB791\uD569\uB2C8\uB2E4. "
